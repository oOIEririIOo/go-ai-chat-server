# Backend 默认模型（用于标题生成和旧客户端兜底）
AI_API_KEY=your_default_ai_api_key
AI_BASE_URL=your_default_ai_base_url
AI_MODEL_ID=your_default_ai_model_id

# 受控模型别名配置（供 model_key 使用）
MODEL_QWEN3_5_FLASH_API_KEY=your_qwen_api_key
MODEL_QWEN3_5_FLASH_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/
MODEL_QWEN3_5_FLASH_MODEL_ID=qwen3.5-flash

MODEL_ZHIPU_GLM_4_FLASH_API_KEY=your_zhipu_api_key
MODEL_ZHIPU_GLM_4_FLASH_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
MODEL_ZHIPU_GLM_4_FLASH_MODEL_ID=glm-4.7-flash

MODEL_OPENAI_GPT_3_5_API_KEY=your_openai_api_key
MODEL_OPENAI_GPT_3_5_BASE_URL=https://api.openai.com/v1/
MODEL_OPENAI_GPT_3_5_MODEL_ID=gpt-3.5-turbo

MODEL_DEEPSEEK_CHAT_API_KEY=your_deepseek_api_key
MODEL_DEEPSEEK_CHAT_BASE_URL=https://api.deepseek.com/
MODEL_DEEPSEEK_CHAT_MODEL_ID=deepseek-chat

# HTTPS server
HTTPS_PORT=443
TLS_CERT_FILE=server.crt
TLS_KEY_FILE=server.key

# Optional services
OSS_BUCKET=your_oss_bucket_name
OSS_ENDPOINT=your_oss_endpoint
OSS_PUBLIC_BASE_URL=your_oss_public_base_url
XFYUN_RTASR_APP_ID=your_xfyun_rtasr_app_id
# XFYUN_RTASR_API_KEY=
# XFYUN_RTASR_URL=
JWT_SECRET=replace_with_a_strong_random_secret
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
